{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "webpack": false,
    "deleteOutDir": true,
    "assets": [
      { "include": "seed/data/**/*.json", "outDir": "dist" },
      { "include": "seed/data/**/*.md", "outDir": "dist" }
    ]
  }
}
